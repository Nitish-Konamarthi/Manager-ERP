# Server
NODE_ENV=production
PORT=3042
HOST=0.0.0.0

# Database (PostgreSQL)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=manager_erp
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT
JWT_SECRET=generate-a-strong-random-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# CORS
CORS_ORIGINS=https://yourdomain.com

# File Uploads
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=10485760

# Idempotency (24h)
IDEMPOTENCY_TTL=86400000
